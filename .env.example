# Copy this file to `.env` (or set these as real environment variables on your
# host / Render service). Spring Boot reads these via ${VAR:default} placeholders
# in src/main/resources/application.properties.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hivtb_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=12345

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
SHOW_SQL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be long enough for HMAC-SHA signing. Override in production.
JWT_SECRET=hivtb2026SecretKeyForJWTTokenGenerationMustBeLongEnough

# ── SMS (Africa's Talking) ────────────────────────────────────────────────────
SMS_ENABLED=false
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=HIVTB

# ── Email (currently disabled — Render free tier blocks outbound SMTP) ────────
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@dreammedical.rw

# ── Firebase Cloud Messaging (push notifications) ─────────────────────────────
# Paste the full Firebase service account JSON as a single-line string.
# If left empty, FCM is silently disabled.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── AI microservice (dose confirmation pattern analysis) ──────────────────────
# Must match the python-ai-service's INTERNAL_API_KEY.
AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_API_KEY=hivtb-internal-key-2026
